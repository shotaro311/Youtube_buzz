# YouTube Data API キー (カンマ区切りで複数指定可)
YOUTUBE_API_KEYS=your-api-key-1,your-api-key-2

# Google Apps Script の保存エンドポイント
GAS_ENDPOINT_URL=https://script.google.com/macros/s/your-endpoint/exec

# Cloudflare Worker URL (検索履歴保存用)
# ローカル: http://localhost:8787
# 本番: https://your-worker.your-subdomain.workers.dev
WORKER_URL=http://localhost:8787

# Cloudflare アカウント関連
CF_ACCOUNT_ID=your-account-id
CF_D1_DATABASE_ID=your-d1-id
